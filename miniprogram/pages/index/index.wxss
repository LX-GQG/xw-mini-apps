.swiper {
  width: 100%;
  height: 86vh;
  position: relative;
}
.swiper image {
  height: 100%;
  width: 100%;
}
.swiper-float-content {
  pointer-events: none;
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.swiper-float-content .title {
  margin-top: 224rpx;
  font-size: 80rpx;
  animation: fadeLeft 1s;
}
.swiper-float-content .descriptions-area {
  margin-top: 580rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 76%;
  justify-content: space-between;
}
.swiper-float-content .descriptions-area .description {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}
.swiper-float-content .descriptions-area .description .description-title {
  font-size: 40rpx;
  margin-bottom: 13rpx;
  animation: fadeIn 0.7s;
}
.swiper-float-content .descriptions-area .description .description-subtitle {
  font-size: 30rpx;
  animation: fadeIn 1.5s;
}
.swiper-float-content .avtion-btn {
  width: 655rpx;
  height: 74rpx;
  color: #fff;
  background-color: rgba(40, 44, 44, 0.4);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 74rpx;
  font-size: 30rpx;
  margin-top: 54rpx;
}
.swiper-float-content .view-config {
  color: #fff;
  margin-top: 23rpx;
  font-size: 25rpx;
  text-decoration: underline;
}
.swiper-float-content .swiper-dots{
  display: flex;
  flex-direction: row;
  align-items: center;
}
.swiper-dots .dot{
  margin-top: 38rpx;
  width: 39rpx;
  height: 4rpx;
  border: none;
  background-color: rgba(255, 255, 255, 0.5);
}
.swiper-dots .dot.active{
  background-color: rgba(255, 255, 255, 1);
}
@keyframes fadeIn {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}
@keyframes fadeLeft {
  0% {
    opacity: 0;
    left: -100px;
  }
  50% {
    opacity: 1;
    left: -150px;
  }
  100% {
    opacity: 1;
    left: 0;
  }
}
